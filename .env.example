# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_APP_ID=your_firebase_app_id

# Gemini API Keys (add up to 5 for rotation)
API_KEY_1=your_gemini_api_key_1_here
API_KEY_2=your_gemini_api_key_2_here
# API_KEY_3=your_gemini_api_key_3_here
# API_KEY_4=your_gemini_api_key_4_here
# API_KEY_5=your_gemini_api_key_5_here

# Optional: Auto-reload endpoint for admin tool
# APP_RELOAD_URL=http://localhost:5000/api/v1/reload
# RELOAD_SECRET=your_secure_random_string_here

# Flask Configuration (optional)
# FLASK_ENV=development
# FLASK_DEBUG=1
